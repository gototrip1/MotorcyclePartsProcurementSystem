<mxfile host="app.diagrams.net" version="24.0.0" type="device">
  <diagram id="motorparts-context-dfd" name="顶层数据流图(0层DFD)">
    <mxGraphModel dx="1500" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1480" pageHeight="460" math="0" background="#10141B" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ================= 中心系统（黑色大方块） ================= -->
        <mxCell id="sys" value="摩托车零部件&#10;采购管理系统" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#161616;strokeColor=#5A5A5A;fontColor=#FFFFFF;fontSize=26;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
