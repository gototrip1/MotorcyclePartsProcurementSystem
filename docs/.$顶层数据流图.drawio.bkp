        <!-- ================= 输入数据流：左侧角色 -> 系统 ================= -->
        <mxCell id="fi1" value="登录 / 审核档案·入库·出库 / 用户管理 / 库存参数 / 报表查询" style="endArrow=classic;html=1;rounded=0;fontColor=#FFFFFF;fontSize=11;strokeColor=#9AA7B8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.15;entryDx=0;entryDy=0;" edge="1" parent="1" source="inAdmin" target="sys"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fi2" value="登录 / 供应商·零件建档 / 创建采购单·录物流 / 提交入库 / 标记付款" style="endArrow=classic;html=1;rounded=0;fontColor=#FFFFFF;fontSize=11;strokeColor=#9AA7B8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="inPurchase" target="sys"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fi3" value="登录 / 创建领用单 / 提交出库申请 / 查询领用状态" style="endArrow=classic;html=1;rounded=0;fontColor=#FFFFFF;fontSize=11;strokeColor=#9AA7B8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.85;entryDx=0;entryDy=0;" edge="1" parent="1" source="inReq" target="sys"><mxGeometry relative="1" as="geometry" /></mxCell>

