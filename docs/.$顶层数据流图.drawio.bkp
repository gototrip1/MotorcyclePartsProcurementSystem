        <mxCell id="fo3" value="&lt;font color=&quot;#4F9BFF&quot;&gt;token&lt;/font&gt;+角色 / 领用单状态 / 出库审核结果 / 库存(只读)" style="endArrow=classic;html=1;rounded=0;fontColor=#FFFFFF;fontSize=11;strokeColor=#9AA7B8;exitX=1;exitY=0.85;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="sys" target="outReq"><mxGeometry relative="1" as="geometry" /></mxCell>

